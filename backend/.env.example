# Server
PORT=3000

# Comma-separated list of allowed CORS origins
CORS_ORIGIN=http://localhost:5173

# JWT signing secret — change this in any real deployment
JWT_SECRET=dev-super-secret-change-me
JWT_EXPIRES_IN=7d

# SQLite database file (relative to backend/)
DATABASE_URL=./airline-claims.db

# Flight search (Google Flights internal endpoint)
FLIGHT_SEARCH_TIMEOUT_MS=20000
# A repeat of the same search within this window reuses the cached results
FLIGHT_SEARCH_CACHE_TTL_MINUTES=10

# Port for the in-process airport gRPC service (fronted by REST /airports)
GRPC_PORT=50051
